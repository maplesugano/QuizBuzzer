{
  "name": "quizbuzzer",
  "version": "1.0.0",
  "description": "A quiz buzzer web app built with React and TypeScript.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "concurrently -k -n server,client -c blue,green \"npm:server\" \"npm:client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}

